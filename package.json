{
  "name": "vscode-acp-client",
  "displayName": "VS Code ACP Client",
  "description": "Chat sessions backed by Agent Client Protocol (ACP) agents and CLIs",
  "version": "0.5.10",
  "publisher": "org-gap",
  "repository": {
    "url": "https://github.com/gayanper/vscode-acp-provider.git"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "type": "commonjs",
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "acp",
    "agent-client-protocol",
    "gemini",
    "chat-sessions",
    "ai"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelChat:copilot",
    "onUri",
    "onFileSystem:ccreq",
    "onFileSystem:ccsettings",
    "onCustomAgentsProvider"
  ],
  "main": "./out/extension.js",
  "enabledApiProposals": [
    "chatSessionsProvider",
    "chatProvider",
    "chatParticipantPrivate",
    "chatParticipantAdditions"
  ],
  "contributes": {
    "chatSessions": [
      {
        "name": "opencode",
        "type": "acp-opencode",
        "canDelegate": true,
        "displayName": "OpenCode [ACP]",
        "description": "Chat sessions backed by the OpenCode ACP agent",
        "commands": [
          {
            "name": "?",
            "description": "List available ACP commands"
          }
        ],
        "icon": "$(hubot)",
        "when": "config.acpClient.agents.opencode.enabled",
        "capabilities": {
          "supportsFileAttachments": true
        }
      },
      {
        "name": "codex",
        "type": "acp-codex",
        "canDelegate": true,
        "displayName": "Codex [ACP]",
        "description": "Chat sessions backed by the Codex ACP agent",
        "commands": [
          {
            "name": "?",
            "description": "List available ACP commands"
          }
        ],
        "icon": "$(hubot)",
        "when": "config.acpClient.agents.codex.enabled",
        "capabilities": {
          "supportsFileAttachments": true
        }
      },
      {
        "name": "cagent",
        "type": "acp-cagent",
        "canDelegate": true,
        "displayName": "Cagent [ACP]",
        "description": "Chat sessions backed by the Cagent ACP agent",
        "commands": [
          {
            "name": "?",
            "description": "List available ACP commands"
          }
        ],
        "icon": "$(hubot)",
        "when": "config.acpClient.agents.cagent.enabled",
        "capabilities": {
          "supportsFileAttachments": true
        }
      },
      {
        "name": "geminicli",
        "type": "acp-geminicli",
        "canDelegate": true,
        "displayName": "Gemini [ACP]",
        "description": "Chat sessions backed by the Gemini CLI ACP agent",
        "commands": [
          {
            "name": "?",
            "description": "List available ACP commands"
          }
        ],
        "icon": "$(hubot)",
        "when": "config.acpClient.agents.geminicli.enabled",
        "capabilities": {
          "supportsFileAttachments": true
        }
      },
      {
        "name": "claude",
        "type": "acp-claude",
        "canDelegate": true,
        "displayName": "Claude Code [ACP]",
        "description": "Chat sessions backed by the Claude Code ACP agent",
        "commands": [
          {
            "name": "?",
            "description": "List available ACP commands"
          }
        ],
        "icon": "$(hubot)",
        "when": "config.acpClient.agents.claude.enabled",
        "capabilities": {
          "supportsFileAttachments": true
        }
      },
      {
        "name": "auggie",
        "type": "acp-auggie",
        "canDelegate": true,
        "displayName": "Auggie [ACP]",
        "description": "Chat sessions backed by the Auggie CLI ACP agent",
        "commands": [
          {
            "name": "?",
            "description": "List available ACP commands"
          }
        ],
        "icon": "$(hubot)",
        "when": "config.acpClient.agents.auggie.enabled",
        "capabilities": {
          "supportsFileAttachments": true
        }
      },
      {
        "name": "vibe",
        "type": "acp-vibe",
        "canDelegate": true,
        "displayName": "Mistral Vibe [ACP]",
        "description": "Chat sessions backed by the Mistral Vibe ACP agent",
        "commands": [
          {
            "name": "?",
            "description": "List available ACP commands"
          }
        ],
        "icon": "$(hubot)",
        "when": "config.acpClient.agents.vibe.enabled",
        "capabilities": {
          "supportsFileAttachments": true
        }
      },
      {
        "name": "copilot",
        "type": "acp-copilot",
        "canDelegate": true,
        "displayName": "Copilot [ACP]",
        "description": "Chat sessions backed by the Copilot ACP agent",
        "commands": [
          {
            "name": "?",
            "description": "List available ACP commands"
          }
        ],
        "icon": "$(hubot)",
        "when": "config.acpClient.agents.copilot.enabled",
        "capabilities": {
          "supportsFileAttachments": true
        }
      }
    ],
    "configuration": {
      "title": "VS Code ACP Client",
      "properties": {
        "acpClient.agents": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": [
              "command"
            ],
            "properties": {
              "label": {
                "type": "string",
                "description": "Display label shown in the chat UI"
              },
              "command": {
                "type": "string",
                "description": "Executable that starts the ACP-compatible CLI"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Optional arguments passed to the CLI"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the process"
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Environment variables merged with the VS Code shell"
              },
              "mcpServers": {
                "type": "array",
                "description": "Optional list of ACP-local MCP servers this agent should connect to when sessions start",
                "items": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "type",
                        "name",
                        "command"
                      ],
                      "properties": {
                        "type": {
                          "const": "stdio",
                          "description": "Connect to an MCP server over stdio"
                        },
                        "name": {
                          "type": "string",
                          "description": "Display name for the MCP server"
                        },
                        "command": {
                          "type": "string",
                          "description": "Executable that launches the MCP server"
                        },
                        "args": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "Arguments passed to the MCP server executable"
                        },
                        "env": {
                          "type": "object",
                          "additionalProperties": {
                            "type": "string"
                          },
                          "description": "Environment variables applied when starting the MCP server"
                        }
                      }
                    },
                    {
                      "type": "object",
                      "required": [
                        "type",
                        "name",
                        "url"
                      ],
                      "properties": {
                        "type": {
                          "const": "http",
                          "description": "Connect to an MCP server over HTTP"
                        },
                        "name": {
                          "type": "string",
                          "description": "Display name for the MCP server"
                        },
                        "url": {
                          "type": "string",
                          "description": "URL of the MCP server"
                        },
                        "headers": {
                          "type": "object",
                          "additionalProperties": {
                            "type": "string"
                          },
                          "description": "Optional HTTP headers sent when connecting to the MCP server"
                        }
                      }
                    }
                  ]
                }
              },
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "Whether this agent should be surfaced in chat"
              },
              "defaultMode": {
                "type": "string",
                "description": "Default mode ID to apply when creating a new chat session"
              },
              "defaultModel": {
                "type": "string",
                "description": "Default model ID to apply when creating a new chat session"
              },
              "defaultThinkingEffort": {
                "type": "string",
                "enum": [
                  "off",
                  "think",
                  "megathink",
                  "ultrathink"
                ],
                "default": "off",
                "description": "Default thinking effort to apply when creating a new chat session"
              }
            }
          },
          "description": "List of ACP agents to use with their command and arguments",
          "default": {
            "cagent": {
              "label": "Cagent",
              "command": "/opt/homebrew/bin/cagent",
              "args": [
                "acp",
                "/path/to/your/agents/cagent.yaml"
              ],
              "mcpServers": [
                {
                  "type": "stdio",
                  "name": "my-stdio-tooling",
                  "command": "/opt/homebrew/bin/my-mcp",
                  "args": [
                    "serve"
                  ]
                },
                {
                  "type": "http",
                  "name": "remote-tooling",
                  "url": "http://localhost:3000"
                }
              ],
              "enabled": false,
              "defaultMode": "code",
              "defaultModel": "gpt-5",
              "defaultThinkingEffort": "megathink"
            }
          }
        }
      }
    },
    "commands": [
      {
        "command": "acp.clearSessions",
        "title": "ACP: Delete all sessions"
      },
      {
        "command": "acp.importAuggieManualCommands",
        "title": "ACP: Import Auggie manual commands"
      }
    ],
    "chatParticipants": [
      {
        "id": "acp-default",
        "fullName": "ACP Agent",
        "name": "acp",
        "isDefault": true,
        "modes": [
          "ask",
          "edit",
          "agent"
        ],
        "when": "!github.copilot-chat.activated"
      }
    ]
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('./out', { recursive: true, force: true })\"",
    "vscode:prepublish": "npm run clean && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "npx prettier . --check",
    "format": "npx prettier . --write",
    "package": "vsce package",
    "install-dts": "npx @vscode/dts 1.120.0",
    "test": "mocha out/*.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.1",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.1",
    "mocha": "^11.7.5",
    "prettier": "3.7.4",
    "typescript": "^5.9.3"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@agentclientprotocol/sdk": "0.14.1"
  }
}
